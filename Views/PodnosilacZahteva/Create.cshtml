@model ZakazivanjeTerminaDTO.PodnosilacZahtevaDTO

@{
    ViewData["Title"] = "Novi podnosilac zahteva";
}

<div class="official-card col-lg-10 mx-auto">
    <h2 class="page-title">Novi podnosilac zahteva</h2>
    <p class="text-muted">
        Unesite osnovne podatke o licu koje podnosi zahtev za izdavanje pasoša.
    </p>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Ime" class="form-label">Ime</label>
                <input asp-for="Ime" class="form-control" />
                <span asp-validation-for="Ime" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Prezime" class="form-label">Prezime</label>
                <input asp-for="Prezime" class="form-control" />
                <span asp-validation-for="Prezime" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="JMBG" class="form-label">JMBG</label>
                <input asp-for="JMBG" class="form-control" maxlength="13" />
                <span asp-validation-for="JMBG" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="DatumRodjenja" class="form-label">Datum rođenja</label>
                <input asp-for="DatumRodjenja" type="date" class="form-control" />
                <span asp-validation-for="DatumRodjenja" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="MestoRodjenja" class="form-label">Mesto rođenja</label>
                <input asp-for="MestoRodjenja" class="form-control" />
                <span asp-validation-for="MestoRodjenja" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Drzavljanstvo" class="form-label">Državljanstvo</label>
                <input asp-for="Drzavljanstvo" class="form-control" />
                <span asp-validation-for="Drzavljanstvo" class="text-danger"></span>
            </div>

            <div class="col-md-8 mb-3">
                <label asp-for="Adresa" class="form-label">Adresa</label>
                <input asp-for="Adresa" class="form-control" />
                <span asp-validation-for="Adresa" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Grad" class="form-label">Grad</label>
                <input asp-for="Grad" class="form-control" />
                <span asp-validation-for="Grad" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Telefon" class="form-label">Telefon</label>
                <input asp-for="Telefon" class="form-control" />
                <span asp-validation-for="Telefon" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" type="email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="BrojLicneKarte" class="form-label">Broj lične karte</label>
                <input asp-for="BrojLicneKarte" class="form-control" />
                <span asp-validation-for="BrojLicneKarte" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-4">
                <label asp-for="DatumVazenjaLicneKarte" class="form-label">Datum važenja lične karte</label>
                <input asp-for="DatumVazenjaLicneKarte" type="date" class="form-control" />
                <span asp-validation-for="DatumVazenjaLicneKarte" class="text-danger"></span>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-outline-secondary">
                Nazad
            </a>

            <button type="submit" class="btn btn-primary-official">
                Sačuvaj podnosioca
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}