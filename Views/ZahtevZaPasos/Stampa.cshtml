@model ZakazivanjeTerminaDTO.PrikazZahtevaZaPasosDTO

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <title>Zahtev za izdavanje pasoša</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 35px;
            color: #111;
        }

        .document {
            width: 850px;
            margin: auto;
        }

        h1 {
            text-align: center;
            font-size: 24px;
            margin-bottom: 25px;
            text-transform: uppercase;
        }

        h3 {
            font-size: 16px;
            margin: 22px 0 8px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 14px;
        }

        td, th {
            border: 1px solid #333;
            padding: 7px;
            font-size: 14px;
        }

        .label {
            font-weight: bold;
            width: 230px;
            background: #f4f4f4;
        }

        .checkbox {
            font-size: 18px;
            text-align: center;
            width: 45px;
        }

        .signatures {
            display: flex;
            justify-content: space-between;
            margin-top: 60px;
        }

        .signature-box {
            width: 280px;
            text-align: center;
        }

        .line {
            border-top: 1px solid #000;
            margin-top: 35px;
            padding-top: 6px;
        }

        .print-button {
            display: block;
            margin: 0 auto 25px;
            padding: 10px 18px;
        }

        @@media print {
            .print-button {
                display: none;
            }

            body {
                margin: 20px;
            }
        }
    </style>
</head>

<body>
    <button class="print-button" onclick="window.print()">Štampaj dokument</button>

    <div class="document">
        <h1>Zahtev za izdavanje pasoša</h1>

        <h3>1. Podaci o podnosiocu zahteva</h3>
        <table>
            <tr>
                <td class="label">Ime:</td>
                <td>@Model.ImePodnosioca</td>
                <td class="label">Prezime:</td>
                <td>@Model.PrezimePodnosioca</td>
            </tr>
            <tr>
                <td class="label">JMBG:</td>
                <td colspan="3">@Model.JMBG</td>
            </tr>
        </table>

        <h3>2. Podaci o zahtevu</h3>
        <table>
            <tr>
                <td class="label">Broj zahteva:</td>
                <td>@Model.BrojZahteva</td>
            </tr>
            <tr>
                <td class="label">Vrsta pasoša:</td>
                <td>@Model.VrstaPasosa</td>
            </tr>
            <tr>
                <td class="label">Razlog izdavanja:</td>
                <td>@Model.RazlogIzdavanja</td>
            </tr>
            <tr>
                <td class="label">Datum podnošenja:</td>
                <td>@Model.DatumPodnosenja.ToString("dd.MM.yyyy.")</td>
            </tr>
            <tr>
                <td class="label">Mesto podnošenja:</td>
                <td>@Model.MestoPodnosenja</td>
            </tr>
            <tr>
                <td class="label">Datum termina:</td>
                <td>@Model.DatumTermina.ToString("dd.MM.yyyy.") @Model.VremeTermina</td>
            </tr>
        </table>

        <h3>3. Dokumentacija</h3>
        <table>
            <tr>
                <td>Važeća lična karta</td>
                <td class="checkbox">@(Model.ImaVazecuLicnuKartu ? "☑" : "☐")</td>
            </tr>
            <tr>
                <td>Dokumentacija kompletna</td>
                <td class="checkbox">@(Model.DokumentacijaKompletna ? "☑" : "☐")</td>
            </tr>
        </table>

        <h3>4. Status zahteva</h3>
        <table>
            <tr>
                <td class="label">Status zahteva:</td>
                <td>@Model.StatusZahteva</td>
            </tr>
            <tr>
                <td class="label">Napomena:</td>
                <td>@(Model.Napomena ?? "")</td>
            </tr>
            <tr>
                <td class="label">Razlog odbijanja:</td>
                <td>@(Model.RazlogOdbijanja ?? "")</td>
            </tr>
        </table>

        <div class="signatures">
            <div class="signature-box">
                <div class="line">Potpis podnosioca zahteva</div>
                <p>Datum: _____________</p>
            </div>

            <div class="signature-box">
                <div class="line">Potpis službenog lica</div>
                <p>Datum: _____________</p>
            </div>
        </div>
    </div>
</body>
</html>