CREATE   PROCEDURE [dbo].[LoginKorisnika]
    @KorisnickoIme NVARCHAR(100),
    @Lozinka NVARCHAR(MAX)
AS
BEGIN
    SELECT Id
    FROM Korisnici
    WHERE KorisnickoIme = @KorisnickoIme
      AND LozinkaHash = @Lozinka
      AND Obrisan = 0
END
