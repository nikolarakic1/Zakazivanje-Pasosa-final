@model ZakazivanjeTerminaDTO.ZahtevZaPasosDTO

@{
    ViewData["Title"] = "Obrada zahteva";
    var id = ViewBag.Id;
}

<div class="official-card col-lg-10 mx-auto">
    <div class="mb-4">
        <h2 class="page-title mb-1">Obrada zahteva za pasoš</h2>
        <p class="text-muted mb-0">
            Izmena statusa, termina i službenih napomena za izabrani zahtev.
        </p>
    </div>

    <form asp-controller="ZahtevZaPasos" asp-action="Edit" asp-route-id="@id" method="post">
        <input type="hidden" asp-for="KorisnikId" />

        <div asp-validation-summary="All" class="alert alert-danger"></div>

        <div class="section-title">1. Podnosilac zahteva</div>

        <div class="mb-4">
            <label asp-for="PodnosilacZahtevaId" class="form-label">
                Lice kome se izrađuje pasoš
            </label>

            <select asp-for="PodnosilacZahtevaId" asp-items="ViewBag.Podnosioci" class="form-select">
                <option value="0">-- Izaberite podnosioca zahteva --</option>
            </select>

            <span asp-validation-for="PodnosilacZahtevaId" class="text-danger"></span>
        </div>

        <div class="section-title">2. Podaci o zahtevu</div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="BrojZahteva" class="form-label">Broj zahteva</label>
                <input asp-for="BrojZahteva" class="form-control" />
                <span asp-validation-for="BrojZahteva" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="StatusZahteva" class="form-label">Status zahteva</label>
                <select asp-for="StatusZahteva" class="form-select">
                    <option>Na čekanju</option>
                    <option>U obradi</option>
                    <option>Dopuna dokumentacije</option>
                    <option>Odobren</option>
                    <option>Odbijen</option>
                    <option>Završen</option>
                </select>
                <span asp-validation-for="StatusZahteva" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="VrstaPasosa" class="form-label">Vrsta pasoša</label>
                <select asp-for="VrstaPasosa" class="form-select">
                    <option>Obični pasoš</option>
                    <option>Službeni pasoš</option>
                    <option>Diplomatski pasoš</option>
                </select>
                <span asp-validation-for="VrstaPasosa" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="RazlogIzdavanja" class="form-label">Razlog izdavanja</label>
                <select asp-for="RazlogIzdavanja" class="form-select">
                    <option>Prvo izdavanje</option>
                    <option>Obnova</option>
                    <option>Zamena zbog isteka</option>
                    <option>Zamena zbog gubitka</option>
                </select>
                <span asp-validation-for="RazlogIzdavanja" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="DatumTermina" class="form-label">Datum termina</label>
                <input asp-for="DatumTermina" type="date" class="form-control" />
                <span asp-validation-for="DatumTermina" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="VremeTermina" class="form-label">Vreme termina</label>
                <input asp-for="VremeTermina" type="time" class="form-control" />
                <span asp-validation-for="VremeTermina" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="MestoPodnosenja" class="form-label">Mesto podnošenja</label>
                <input asp-for="MestoPodnosenja" class="form-control" />
                <span asp-validation-for="MestoPodnosenja" class="text-danger"></span>
            </div>
        </div>

        <div class="section-title">3. Provera uslova</div>

        <div class="condition-box mb-4">
            <div class="form-check mb-2">
                <input asp-for="ImaVazecuLicnuKartu" class="form-check-input" />
                <label asp-for="ImaVazecuLicnuKartu" class="form-check-label">
                    Podnosilac ima važeću ličnu kartu
                </label>
            </div>

            <div class="form-check">
                <input asp-for="DokumentacijaKompletna" class="form-check-input" />
                <label asp-for="DokumentacijaKompletna" class="form-check-label">
                    Dokumentacija je kompletna
                </label>
            </div>
        </div>

        <div class="section-title">4. Službene napomene</div>

        <div class="mb-3">
            <label asp-for="Napomena" class="form-label">Napomena</label>
            <textarea asp-for="Napomena" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Napomena" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="RazlogOdbijanja" class="form-label">Razlog odbijanja</label>
            <textarea asp-for="RazlogOdbijanja" class="form-control" rows="3"
                      placeholder="Popunjava se ako je zahtev odbijen"></textarea>
            <span asp-validation-for="RazlogOdbijanja" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-outline-secondary">
                Nazad
            </a>

            <button type="submit" class="btn btn-primary-official">
                Sačuvaj izmene
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}