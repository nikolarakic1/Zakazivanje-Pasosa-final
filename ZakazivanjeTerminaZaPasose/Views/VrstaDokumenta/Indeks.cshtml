@model List<ZakazivanjeTerminaDTO.PrikazVrsteDokumentaDTO>

@{
    ViewData["Title"] = "Vrste dokumenata";
}

<div class="official-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title mb-1">Vrste dokumenata</h2>
            <p class="text-muted mb-0">
                Pregled šifarnika dokumenata potrebnih za podnošenje zahteva za pasoš.
            </p>
        </div>

        <a asp-controller="VrstaDokumenta" asp-action="Napravi" class="btn btn-primary-official">
            + Nova vrsta dokumenta
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Trenutno nema unetih vrsta dokumenata.
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Naziv dokumenta</th>
                    <th>Opis</th>
                    <th>Obavezan</th>
                    <th class="text-center" style="width: 220px;">Akcije</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var dokument in Model)
                {
                    <tr>
                        <td class="fw-semibold">@dokument.Naziv</td>

                        <td>@dokument.Opis</td>

                        <td>
                            @if (dokument.Obavezno)
                            {
                                <span class="badge bg-danger">Da</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ne</span>
                            }
                        </td>

                        <td class="text-center">
                            <a asp-controller="VrstaDokumenta"
                               asp-action="Izmeni"
                               asp-route-id="@dokument.Id"
                               class="btn btn-sm btn-outline-primary">
                                Izmeni
                            </a>

                            <form asp-controller="VrstaDokumenta"
                                  asp-action="Obrisi"
                                  asp-route-id="@dokument.Id"
                                  method="post"
                                  class="d-inline"
                                  onsubmit="return confirm('Da li ste sigurni da želite da obrišete ovu vrstu dokumenta?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Obriši
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>