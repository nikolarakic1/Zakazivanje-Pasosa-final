@model ZakazivanjeTerminaDTO.VrstaDokumentaDTO

@{
    ViewData["Title"] = "Izmena vrste dokumenta";
    var id = ViewBag.Id;
}

<div class="official-card col-lg-7 mx-auto">
    <h2 class="page-title">Izmena vrste dokumenta</h2>
    <p class="text-muted">
        Izmenite podatke postojeće vrste dokumenta.
    </p>

    <form asp-action="Edit" asp-route-id="@id" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Naziv" class="form-label">Naziv dokumenta</label>
            <input asp-for="Naziv" class="form-control" />
            <span asp-validation-for="Naziv" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Opis" class="form-label">Opis</label>
            <textarea asp-for="Opis" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Opis" class="text-danger"></span>
        </div>

        <div class="form-check mb-4">
            <input asp-for="Obavezno" class="form-check-input" />
            <label asp-for="Obavezno" class="form-check-label">
                Dokument je obavezan
            </label>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-outline-secondary">
                Nazad
            </a>

            <button type="submit" class="btn btn-primary-official">
                Sačuvaj izmene
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}