@model List<ZakazivanjeTerminaDTO.PrikazDokumentacijaDTO>

@{
    ViewData["Title"] = "Dokumentacija";
    var grupe = Model
        .GroupBy(x => new { x.ZahtevZaPasosId, x.BrojZahteva, x.Podnosilac })
        .ToList();
}

<div class="official-card">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="page-title mb-1">Dokumentacija zahteva</h2>
            <p class="text-muted mb-0">
                Pregled i uređivanje dostavljene dokumentacije za svaki zahtev za pasoš.
            </p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Trenutno nema evidentirane dokumentacije. Dokumentacija se automatski kreira nakon unosa zahteva.
        </div>
    }
    else
    {
        @foreach (var grupa in grupe)
        {
            var ukupno = grupa.Count();
            var dostavljeno = grupa.Count(x => x.Dostavljeno);

            <div class="documentation-group mb-4">
                <div class="documentation-group-header">
                    <div>
                        <h5 class="mb-1">Zahtev: @grupa.Key.BrojZahteva</h5>
                        <div class="text-muted">
                            Podnosilac: <strong>@grupa.Key.Podnosilac</strong>
                        </div>
                    </div>

                    <div class="text-end">
                        <div class="mb-2">
                            <span class="status-badge">
                                Dostavljeno @dostavljeno / @ukupno
                            </span>
                        </div>

                        <a asp-controller="Dokumentacija"
                           asp-action="UrediZaZahtev"
                           asp-route-zahtevId="@grupa.Key.ZahtevZaPasosId"
                           class="btn btn-sm btn-primary-official">
                            Uredi dokumentaciju
                        </a>
                    </div>
                </div>

                <div class="table-responsive mt-3">
                    <table class="table table-bordered table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Dokument</th>
                                <th>Obavezno</th>
                                <th>Dostavljeno</th>
                                <th>Datum</th>
                                <th>Napomena</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var d in grupa)
                            {
                                <tr>
                                    <td class="fw-semibold">@d.NazivDokumenta</td>

                                    <td>
                                        @if (d.Obavezno)
                                        {
                                            <span class="status-badge status-rejected">Da</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge">Ne</span>
                                        }
                                    </td>

                                    <td>
                                        @if (d.Dostavljeno)
                                        {
                                            <span class="status-badge status-approved">Dostavljeno</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-rejected">Nije dostavljeno</span>
                                        }
                                    </td>

                                    <td>@(d.DatumDostavljanja?.ToString("dd.MM.yyyy.") ?? "-")</td>

                                    <td>@(d.Napomena ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>