@model ZakazivanjeTerminaDTO.DokumentacijaDTO

@{
    ViewData["Title"] = "Izmena dokumentacije";
    var id = ViewBag.Id;
}

<div class="official-card col-lg-8 mx-auto">
    <h2 class="page-title mb-1">Izmena dokumentacije</h2>
    <p class="text-muted">
        Izmenite podatke o dokumentu koji je vezan za konkretan zahtev za pasoš.
    </p>

    <form asp-controller="Dokumentacija" asp-action="Izmeni" asp-route-id="@id" method="post">
        <div asp-validation-summary="All" class="alert alert-danger"></div>

        <div class="section-title">Podaci o dokumentaciji</div>

        <div class="mb-3">
            <label asp-for="ZahtevZaPasosId" class="form-label">Zahtev za pasoš</label>
            <select asp-for="ZahtevZaPasosId" asp-items="ViewBag.Zahtevi" class="form-select">
                <option value="0">-- Izaberite zahtev --</option>
            </select>
            <span asp-validation-for="ZahtevZaPasosId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="VrstaDokumentaId" class="form-label">Vrsta dokumenta</label>
            <select asp-for="VrstaDokumentaId" asp-items="ViewBag.VrsteDokumenata" class="form-select">
                <option value="0">-- Izaberite vrstu dokumenta --</option>
            </select>
            <span asp-validation-for="VrstaDokumentaId" class="text-danger"></span>
        </div>

        <div class="condition-box mb-3">
            <div class="form-check">
                <input asp-for="Dostavljeno" class="form-check-input" />
                <label asp-for="Dostavljeno" class="form-check-label">
                    Dokument je dostavljen
                </label>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="DatumDostavljanja" class="form-label">Datum dostavljanja</label>
            <input asp-for="DatumDostavljanja" type="date" class="form-control" />
            <span asp-validation-for="DatumDostavljanja" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Napomena" class="form-label">Napomena</label>
            <textarea asp-for="Napomena" class="form-control" rows="3"
                      placeholder="Unesite napomenu ako postoji"></textarea>
            <span asp-validation-for="Napomena" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-controller="Dokumentacija" asp-action="index" class="btn btn-outline-secondary">
                Nazad
            </a>

            <button type="submit" class="btn btn-primary-official">
                Sačuvaj izmene
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}