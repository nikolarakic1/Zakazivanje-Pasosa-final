@model List<ZakazivanjeTerminaDTO.PodnosilacZahtevaDTO>

@{
    ViewData["Title"] = "Podnosioci zahteva";
}

<div class="official-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title mb-1">Podnosioci zahteva</h2>
            <p class="text-muted mb-0">
                Evidencija lica koja podnose zahtev za izdavanje pasoša.
            </p>
        </div>

        <a asp-controller="PodnosilacZahteva" asp-action="Napravi" class="btn btn-primary-official">
            + Dodaj podnosioca
        </a>
    </div>

    <div class="alert alert-light border">
        Broj učitanih podnosilaca: <strong>@Model.Count</strong>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Trenutno nema unetih podnosilaca zahteva.
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Ime i prezime</th>
                    <th>JMBG</th>
                    <th>Grad</th>
                    <th>Telefon</th>
                    <th>Lična karta važi do</th>
                    <th class="text-center" style="width: 220px;">Akcije</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="fw-semibold">@p.Ime @p.Prezime</td>
                        <td>@p.JMBG</td>
                        <td>@p.Grad</td>
                        <td>@p.Telefon</td>
                        <td>@p.DatumVazenjaLicneKarte.ToString("dd.MM.yyyy.")</td>

                        <td class="text-center">
                            <a asp-controller="PodnosilacZahteva"
                               asp-action="Izmeni"
                               asp-route-id="@p.Id"
                               class="btn btn-sm btn-outline-primary">
                                Izmeni
                            </a>

                            <form asp-controller="PodnosilacZahteva"
                                  asp-action="Obrisi"
                                  asp-route-id="@p.Id"
                                  method="post"
                                  class="d-inline"
                                  onsubmit="return confirm('Da li ste sigurni da želite da obrišete podnosioca zahteva?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Obriši
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>